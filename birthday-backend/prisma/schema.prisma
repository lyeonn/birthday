generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int    @id @default(autoincrement())
  token    String @unique @default(uuid()) @db.Uuid
  nickname String @db.VarChar(20)
  pin      String @db.VarChar(4) // 4자리 PIN (평문) — 카카오 로그인 붙기 전 임시 식별자

  // 카카오 로그인용 (지금은 anonymous, 연동 시 채워짐)
  authProvider    AuthProvider @default(anonymous)
  kakaoId         String?      @unique @db.VarChar(64)
  email           String?      @db.VarChar(255)
  profileImageUrl String?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  hostedPages    Page[]         @relation("PageHost")
  messages       Message[]      @relation("MessageAuthor")
  uploadedPhotos Photo[]        @relation("PhotoUploader")
  photoComments  PhotoComment[] @relation("PhotoCommentAuthor")

  @@unique([nickname, pin]) // (닉네임, PIN) 조합이 user 식별자
}

enum AuthProvider {
  anonymous
  kakao
}

model Page {
  id         Int      @id @default(autoincrement())
  code       String   @unique @db.VarChar(6)
  hostId     Int
  friendName String   @db.VarChar(20)
  birthday   DateTime @db.Date
  greeting   String   @db.VarChar(60)
  color      String   @db.Char(7)
  photoUrl   String?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  host     User      @relation("PageHost", fields: [hostId], references: [id], onDelete: Cascade)
  messages Message[]
  photos   Photo[]

  @@index([hostId])
}

model Message {
  id        Int     @id @default(autoincrement())
  pageId    Int
  authorId  Int
  content   String  @db.Text
  photoUrl  String?
  cardColor String? @db.Char(7)

  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  deletedAt DateTime? @db.Timestamptz

  page   Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  author User @relation("MessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([pageId, createdAt(sort: Desc)])
}

// 갤러리 사진 — 메시지 첨부 사진과 완전히 별개, 호스트/친구 모두 등록 가능
model Photo {
  id         Int    @id @default(autoincrement())
  pageId     Int
  uploaderId Int
  url        String

  createdAt DateTime @default(now()) @db.Timestamptz

  page     Page           @relation(fields: [pageId], references: [id], onDelete: Cascade)
  uploader User           @relation("PhotoUploader", fields: [uploaderId], references: [id], onDelete: Cascade)
  comments PhotoComment[]

  @@index([pageId, createdAt(sort: Desc)])
}

// 갤러리 사진에 달리는 댓글
model PhotoComment {
  id       Int    @id @default(autoincrement())
  photoId  Int
  authorId Int
  content  String @db.VarChar(300)

  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  deletedAt DateTime? @db.Timestamptz

  photo  Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)
  author User  @relation("PhotoCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([photoId, createdAt(sort: Asc)])
}
